      <VBox minWidth="-Infinity" prefHeight="390.0" prefWidth="230.0" spacing="8.0" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#openChequing" prefHeight="18.0" prefWidth="116.0" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 14;" text="Open Chequing" />
            <Button fx:id="openSavings" mnemonicParsing="false" onAction="#openSavings" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 14;" text="Open Savings" />
            <Button fx:id="openInvestment" mnemonicParsing="false" onAction="#openInvestment" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 14;" text="Open Investment" />
            <Button fx:id="deposit" mnemonicParsing="false" onAction="#deposit" style="-fx-background-color: #16a34a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 14;" text="Deposit" />
