            <Button fx:id="applyInterest" mnemonicParsing="false" onAction="#applyInterest" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 14;" text="Apply Interest" />
            <Button fx:id="applyMonthlyFees" mnemonicParsing="false" onAction="#applyMonthlyFees" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 14;" text="Apply Monthly Fees" />
