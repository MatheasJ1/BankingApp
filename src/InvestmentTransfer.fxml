<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="InvestmentTransferController">
   <children>
      <Label text="Investment Transfer">
         <font>
            <Font size="26.0" />
         </font>
      </Label>
      <ComboBox fx:id="investmentBox" prefWidth="150.0" promptText="Choose Account" />
      <TextField fx:id="amountField" promptText="Amount" />
      <Button mnemonicParsing="false" onAction="#transferToChequing" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 14;" text="Transfer" />
      <Label fx:id="messageLabel" text="Message" />
   </children>
</VBox>
